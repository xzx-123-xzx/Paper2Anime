# ========== 应用配置 ==========
APP_NAME=Paper2Anime
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# ========== 后端服务 ==========
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173

# ========== 数据库 ==========
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=paper2anime
MYSQL_PASSWORD=paper2anime123
MYSQL_DATABASE=paper2anime

# ========== Redis ==========
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis123
REDIS_DB=0

# ========== LLM 配置 (DeepSeek) ==========
MODEL_API_KEY=your-deepseek-api-key
MODEL_BASE_URL=https://api.deepseek.com
MODEL_NAME=deepseek-chat
MODEL_MAX_TOKENS=8192
MODEL_TEMPERATURE=0.7

# ========== MinMax 文生图 ==========
MINMAX_IMAGE_API_KEY=your-minmax-image-key
MINMAX_IMAGE_API_URL=https://api.minimax.chat/v1/image_generation
MINMAX_IMAGE_MODEL=imgen-3.0

# ========== MinMax 文生视频 ==========
MINMAX_VIDEO_API_KEY=your-minmax-video-key
MINMAX_VIDEO_API_URL=https://api.minimax.chat/v1/video_generation
MINMAX_VIDEO_MODEL=video-01

# ========== 存储配置 ==========
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=/app/storage

# S3 配置（可选）
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=paper2anime
S3_REGION=us-east-1

# ========== FFmpeg ==========
FFMPEG_PATH=/usr/bin/ffmpeg
FFMPEG_THREADS=8

# ========== Celery ==========
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ========== 日志 ==========
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log

# ========== 成本控制 ==========
MAX_COST_PER_PROJECT=100.0
ENABLE_COST_ALERT=true
COST_ALERT_THRESHOLD=80.0

# ========== 质量控制 ==========
QUALITY_THRESHOLD=0.75
MAX_RETRIES=3
